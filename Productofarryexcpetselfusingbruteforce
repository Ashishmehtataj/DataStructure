#include<iostream>
using namespace std;
int main(){
	int arr[] = {10,20,3,40};
	int size = sizeof(arr)/sizeof(int);
	int ans[];
	for(int i=0;i<size;i++){
		int production = 1;
		for(int j=0;j<size;j++){
			if(i != j){
				production = production*arr[j];
			}
		}
		ans[i] = production;
	}
	return ans;
}

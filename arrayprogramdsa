int biggest(int arr[],int size){
	int ans = 0;
	for(int i=0;i<size;i++){
		if(arr[i]>ans){
			ans = arr[i];
		}
	}
	return ans;
}

int lowest(int arr[],int size){
	int ans = 0;
	for(int i=0;i<size;i++){
		if(arr[i]<ans){
			ans = arr[i];
		}
	}
	return ans;
}

int sum(int arr[],int size){
	int ans = 0;
	for(int i=0;i<size;i++){
		ans = ans+arr[i];
	}
	return ans;
}

float avg(int arr[],int size){
	
	int ans = sum(arr,size);
	float avgg = (float)ans/size;
	return avgg;	
	
}

int reverse(int arr[],int size){
	int first = 0;
	int last = size-1;
	while(first<last){
		swap(arr[first],arr[last]);
		first++;
		last--;
	}
}


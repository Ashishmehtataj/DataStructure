int maxsubarraysumusingkadanalgo(int arr[],int size){
	int msum = INT_MIN;
	
	for(int str=0;str<size;str++){
		int currentsum = 0;
		for(int end=str;end<size;end++){
			currentsum = currentsum+arr[end];
			msum = max(currentsum,msum);
		}
	}
	return msum;
}

int sumofsubarrayusingbrutefoce(int arr[],int size){
	int currentsum = 0,maxsum = INT_MIN;
	for(int str=0;str<size;str++){
		for(int end=str;end<size;end++){
			int sum = 0;
			for(int i=str;i<=end;i++){
				sum = sum+arr[i];
			}
			maxsum = max(sum,maxsum);
		}
	}
	return maxsum;
}

int pairsumoptimalapproach(int arr[],int size,int target){
	int i = 0;
	int j = size-1;
	while(i<j){
		
		int pairsum = arr[i]+arr[j];
		if(pairsum>target){
			j--;
		}else if(pairsum<target){
			i++;
		}else{
			cout<<i<<" and "<<j;
			i++;
			j--;
		}
	}
}


int majorityelement(int arr[],int size){
	for(int i=0;i<size;i++){
		int freq = 0;
		for(int j=0;j<size;j++){
			if(arr[i]==arr[j]){
				freq++;
			}
		}
		if(freq>size/2){
			return arr[i];
		}
	}
}





















